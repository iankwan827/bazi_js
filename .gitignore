# Ignore everything by default
/*

# Un-ignore the js folder and its contents
!js/
!js/**

# Un-ignore the doc folder and its contents
!doc/
!doc/**

# Also keep root configuration and documentation
!.gitignore
!sync_to_github.bat
!README.md

# Ignore specific test outputs even if they were in un-ignored folders (though they are not)
test_output.md
test_error.log
*.log

# 八字词汇表
!BAZI_VOCABULARY.md
